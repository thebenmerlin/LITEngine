# Hugging Face API Configuration
HUGGINGFACE_API_KEY=hf_your_api_key_here

# Kanoon (Indian Legal Database) Configuration
KANOON_BASE_URL=https://api.kanoon.example.com/v1

# CORS Configuration (comma-separated origins, use * for dev)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Server Configuration
PORT=8000

# Logging Level
LOG_LEVEL=INFO

# Cache TTL in seconds
CACHE_TTL=3600
